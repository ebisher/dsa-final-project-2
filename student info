struct Student {
    std::string name;       // string of chars
    float       gpa;        // float  (0.0 – 4.0)
    int         id;         // integer
    int         classYear;  // integer
    std::string major;
    std::string activities;
};

void printStudent(const Student& s) {
    std::cout << std::fixed << std::setprecision(2);
    std::cout << "  Name       : " << s.name        << "\n"
              << "  ID         : " << s.id           << "\n"
              << "  GPA        : " << s.gpa          << "\n"
              << "  Class Year : " << s.classYear    << "\n"
              << "  Major      : " << s.major        << "\n"
              << "  Activities : " << s.activities   << "\n";
}

void printHeader(const std::string& title) {
    std::cout << "\n========================================\n"
              << "  " << title << "\n"
              << "========================================\n";
}


//  StudentSystem (manages the roster)
class StudentSystem {
private:
    std::vector<Student> students;
    bool isSorted = false;   // tracks whether vector is sorted by ID

    void ensureSorted() {
        if (!isSorted) {
            std::sort(students.begin(), students.end(),
                      [](const Student& a, const Student& b){
                          return a.id < b.id;
                      });
            isSorted = true;
        }
    }

    bool idExists(int id) const {
        for (const auto& s : students)
            if (s.id == id) return true;
        return false;
    }

public:
    bool addStudent(const Student& s) {
        if (idExists(s.id)) {
            std::cout << "  [Error] Student with ID " << s.id << " already exists.\n";
            return false;
        }
        if (s.gpa < 0.0f || s.gpa > 4.0f) {
            std::cout << "  [Error] GPA must be between 0.0 and 4.0.\n";
            return false;
        }
        students.push_back(s);
        isSorted = false;
        std::cout << "  Student '" << s.name << "' added successfully.\n";
        return true;
    }

    bool updateStudent(int id, const Student& updated) {
        for (auto& s : students) {
            if (s.id == id) {
                if (updated.gpa < 0.0f || updated.gpa > 4.0f) {
                    std::cout << "  [Error] GPA must be between 0.0 and 4.0.\n";
                    return false;
                }
                s = updated;
                s.id = id;          // preserve original ID
                isSorted = false;
                std::cout << "  Record updated.\n";
                return true;
            }
        }
        std::cout << "  [Error] Student ID " << id << " not found.\n";
        return false;
    }

    bool deleteStudent(int id) {
        auto it = std::remove_if(students.begin(), students.end(),
                                 [id](const Student& s){ return s.id == id; });
        if (it == students.end()) {
            std::cout << "  [Error] Student ID " << id << " not found.\n";
            return false;
        }
        students.erase(it, students.end());
        std::cout << "  Student ID " << id << " deleted.\n";
        return true;
    }

    void listAll() const {
        if (students.empty()) {
            std::cout << "  No students on record.\n";
            return;
        }
        std::cout << std::fixed << std::setprecision(2);
        std::cout << "\n  "
                  << std::left
                  << std::setw(6)  << "ID"
                  << std::setw(24) << "Name"
                  << std::setw(8)  << "GPA"
                  << std::setw(12) << "Class Year"
                  << "Major\n";
        std::cout << "  " << std::string(60, '-') << "\n";
        for (const auto& s : students) {
            std::cout << "  "
                      << std::left
                      << std::setw(6)  << s.id
                      << std::setw(24) << s.name
                      << std::setw(8)  << s.gpa
                      << std::setw(12) << s.classYear
                      << s.major << "\n";
        }
    }

    // ── GPA utilities ─────────────────────────

    void showHonorsRoll(float threshold = 3.8f) const {
        printHeader("Honors Roll  (GPA >= " + std::to_string(threshold).substr(0,3) + ")");
        bool any = false;
        for (const auto& s : students) {
            if (s.gpa >= threshold) {
                printStudent(s);
                std::cout << "  ----------------------------------------\n";
                any = true;
            }
        }
        if (!any) std::cout << "  No students meet the threshold.\n";
    }

    void showClassYear(int year) const {
        printHeader("Students in Class Year " + std::to_string(year));
        bool any = false;
        for (const auto& s : students) {
            if (s.classYear == year) {
                printStudent(s);
                std::cout << "  ----------------------------------------\n";
                any = true;
            }
        }
        if (!any) std::cout << "  No students found for class year " << year << ".\n";
    }

    float averageGPA() const {
        if (students.empty()) return 0.0f;
        float sum = 0.0f;
        for (const auto& s : students) sum += s.gpa;
        return sum / students.size();
    }

    int size() const { return static_cast<int>(students.size()); }
};

//  Input helpers
int readInt(const std::string& prompt) {
    int val;
    while (true) {
        std::cout << prompt;
        if (std::cin >> val) { std::cin.ignore(); return val; }
        std::cin.clear();
        std::cin.ignore(std::numeric_limits<std::streamsize>::max(), '\n');
        std::cout << "  [Error] Please enter a valid integer.\n";
    }
}

float readFloat(const std::string& prompt) {
    float val;
    while (true) {
        std::cout << prompt;
        if (std::cin >> val) { std::cin.ignore(); return val; }
        std::cin.clear();
        std::cin.ignore(std::numeric_limits<std::streamsize>::max(), '\n');
        std::cout << "  [Error] Please enter a valid number.\n";
    }
}

std::string readLine(const std::string& prompt) {
    std::string val;
    std::cout << prompt;
    std::getline(std::cin, val);
    return val;
}

Student inputStudent() {
    Student s;
    s.name       = readLine("  Name        : ");
    s.id         = readInt ("  ID (int)    : ");
    s.gpa        = readFloat("  GPA (float) : ");
    s.classYear  = readInt ("  Class Year  : ");
    s.major      = readLine("  Major       : ");
    s.activities = readLine("  Activities  : ");
    return s;
}


